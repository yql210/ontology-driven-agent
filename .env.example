# LayerKG 环境配置
# 复制本文件为 .env 并填入实际值：cp .env.example .env

# ---- Neo4j ----
LAYERKG_NEO4J_URI=bolt://localhost:7687
LAYERKG_NEO4J_USER=neo4j
LAYERKG_NEO4J_PASSWORD=

# ---- Ollama（本地 LLM / Embedding）----
LAYERKG_OLLAMA_URL=http://localhost:11434
LAYERKG_EMBEDDING_MODEL=qwen2.5-coder:0.5b
LAYERKG_LLM_MODEL=qwen3.5:9b

# ---- 语义提取 LLM（可选，替代 Ollama）----
# 提供商：ollama（默认）| openai
# LAYERKG_SEMANTIC_LLM_PROVIDER=openai
# OpenAI API Key（provider=openai 时必填）
# LAYERKG_SEMANTIC_API_KEY=sk-xxx
# OpenAI 兼容 API base URL
# LAYERKG_SEMANTIC_BASE_URL=https://api.openai.com/v1

# ---- ChromaDB ----
LAYERKG_CHROMA_DIR=.chroma

# ---- 构建选项 ----
# 是否包含文档文件（.md/.rst）
LAYERKG_BUILD_INCLUDE_DOCS=true
# 文档扩展名（逗号分隔）
# LAYERKG_BUILD_DOC_EXTENSIONS=.md,.rst
# 文档最大长度（字符数）
# LAYERKG_BUILD_DOC_MAX_LENGTH=2000
# 跳过的目录（逗号分隔）
# LAYERKG_BUILD_SKIP_DIRS=__pycache__,.git,.mypy_cache,.ruff_cache,.pytest_cache,node_modules,.venv,venv,site,.tox,dist,build,*.egg-info

# ---- Agent LLM（可选，用于 Agent 交互）----
LAYERKG_AGENT_LLM_PROVIDER=zhipu
LAYERKG_AGENT_LLM_MODEL=glm-4-flash
LAYERKG_AGENT_API_KEY=
LAYERKG_AGENT_BASE_URL=https://open.bigmodel.cn/api/anthropic
